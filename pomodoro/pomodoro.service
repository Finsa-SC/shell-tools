[Unit]
Description=Pomodoro Auto Sleep Service with Safety Switch
After=suspend.target

[Service]
Type=simple
User=silence-suzuka
Environment="DISPLAY=:0"
Environment="DBUS_SESSION_BUS_ADDRESS=unix:path=/run/user/1000/bus"
ExecStart=/usr/local/bin/pomodoro.sh
Restart=always
RestartSec=3

[Install]
WantedBy=default.target


